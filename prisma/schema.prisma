generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model PointAudit {
  id                   String @id @default(auto()) @map("_id") @db.ObjectId
  v                    Int    @map("__v")
  createdAt            String
  destinationDiscordId String
  messageId            String
  pointsGiven          Int
  sourceDiscordId      String
  type                 String
  itemId               Int?
  bossName             String?
  osrsName             String?
  // COMPETITION audits only — the WOM competition that paid out, stamped by the bot at award
  // time (older rows backfilled best-guess by the bot's backfillCompetitionAudits migration).
  competitionId        Int?
  competitionTitle     String?
  // 1-based finishing position (ties share it); absent when the member couldn't be ranked.
  placement            Int?
}

model Users {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  v         Int    @map("__v")
  discordId String @unique
  joined    String
  points    Int
  // Separate bucket for clan activity (group raids, events, competitions). Optional: legacy user
  // docs predate the field until the bot touches them; readers coalesce to 0.
  clanPoints Int?
}

model UserNicknames {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  discordId String
  nickname  String
}

model UserAlts {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  discordId String
  altName  String
}

model ClanEvents {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  v               Int     @map("__v")
  type            String
  startDate       String
  endDate         String
  winnerDiscordId String?
  winnerOsrsName  String?
}

model EventPolls {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  v                  Int     @map("__v")
  pollType           String
  status             String
  winnerMetric       String?
  relatedClanEventId String? @db.ObjectId
}

// Per-participant award breakdown embedded in a RaidCompletion (written by the Discord bot).
type RaidParticipantAward {
  discordId             String
  basePoints            Int
  bonusPoints           Int
  newTeammateDiscordIds String[]
  rotwApplied           Boolean
  capped                Boolean
  totalPoints           Int
}

model RaidCompletions {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  v                     Int?                   @map("__v")
  // Exact WOM variant metric submitted, e.g. 'theatre_of_blood_hard_mode'.
  raidMetric            String
  // Normal-mode metric of the same raid, e.g. 'theatre_of_blood'.
  baseRaidMetric        String
  // Human-readable name at save time, e.g. 'Theatre Of Blood Hard Mode'.
  raidDisplayName       String
  participantDiscordIds String[]
  submitterDiscordId    String
  screenshotUrl         String?
  proofMessageUrl       String?
  approvalMessageId     String                 @unique
  approvedByDiscordId   String
  rotwApplied           Boolean
  awards                RaidParticipantAward[]
  createdAt             String
  approvedAt            String
}

model PersonalBests {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  v                     Int?     @map("__v")
  bossName              String
  raidLevel             Int?
  scale                 Int
  categoryKey           String
  timeDisplay           String
  timeSeconds           Float
  // Whether the time was submitted with a decimal (in-game precise timing on). Optional: legacy
  // rows lack these until the bot's backfillPbPreciseTiming migration runs; readers coalesce.
  isPreciseTime         Boolean?
  // Ranking value: timeSeconds, plus the worst-case +0.4s penalty when the time had no decimal.
  effectiveTimeSeconds  Float?
  participantDiscordIds String[]
  participantAltNames   String[]
  submitterDiscordId    String
  screenshotUrl         String?
  proofMessageUrl       String?
  approvalMessageId     String   @unique
  approvedByDiscordId   String
  createdAt             String
  approvedAt            String
}
