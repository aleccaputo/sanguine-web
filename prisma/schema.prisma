generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model PointAudit {
  id                   String @id @default(auto()) @map("_id") @db.ObjectId
  v                    Int    @map("__v")
  createdAt            String
  destinationDiscordId String
  messageId            String
  pointsGiven          Int
  sourceDiscordId      String
  type                 String
  itemId               Int?
  bossName             String?
  osrsName             String?
}

model Users {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  v         Int    @map("__v")
  discordId String @unique
  joined    String
  points    Int
}

model UserNicknames {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  discordId String
  nickname  String
}

model UserAlts {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  discordId String
  altName  String
}

model ClanEvents {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  v               Int     @map("__v")
  type            String
  startDate       String
  endDate         String
  winnerDiscordId String?
  winnerOsrsName  String?
}

model EventPolls {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  v                  Int     @map("__v")
  pollType           String
  status             String
  winnerMetric       String?
  relatedClanEventId String? @db.ObjectId
}
